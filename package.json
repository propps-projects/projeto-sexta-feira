{
  "name": "mcp-agentclass",
  "version": "0.1.0",
  "description": "MCP server that turns a Panda Video micro-course into an agentic tutor for Claude and ChatGPT",
  "type": "module",
  "private": true,
  "scripts": {
    "ingest:1-fetch": "tsx scripts/1-fetch-lessons.ts",
    "ingest:2-audio": "tsx scripts/2-extract-audio.ts",
    "ingest:3-transcribe": "tsx scripts/3-transcribe.ts",
    "ingest:4-index": "tsx scripts/4-index.ts",
    "ingest:all": "npm run ingest:1-fetch && npm run ingest:2-audio && npm run ingest:3-transcribe && npm run ingest:4-index",
    "server": "tsx src/server.ts",
    "server:http": "tsx src/server-http.ts",
    "inspect": "npx @modelcontextprotocol/inspector tsx src/server.ts",
    "db:check": "tsx scripts/check-supabase.ts",
    "tenant:create": "tsx scripts/cli/create-tenant.ts",
    "import:vma": "tsx scripts/cli/import-mvp-data.ts",
    "import:vma:api": "tsx scripts/cli/import-mvp-data-api.ts",
    "hotmart:link": "tsx scripts/cli/link-hotmart-product.ts",
    "oauth:register": "tsx scripts/cli/register-oauth-client.ts",
    "admin:invite": "tsx scripts/cli/invite-admin.ts"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "@mcp-ui/server": "^5.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "busboy": "^1.6.0",
    "dotenv": "^16.4.0",
    "hls.js": "^1.6.16",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.9",
    "sqlite-vec": "^0.1.6",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/busboy": "^1.5.4",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
