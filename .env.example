# Panda Video API key (the literal string, no "Bearer" prefix — Panda uses it raw in the Authorization header)
PANDA_API_KEY=panda-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Folder ID for the course inside Panda (VMA folder by default)
PANDA_FOLDER_ID=1c52c2e9-500e-4fde-b2aa-35e9f0aa5c11

# OpenAI API key — used for Whisper transcription (whisper-1, returns verbose_json with timestamps)
# ~$0.006/min ≈ $0.60 for the full 13-lesson VMA course.
OPENAI_API_KEY=sk-...

# Course language (ISO-639-1) — passed to Whisper to lock the target language
COURSE_LANG=pt

# --- HTTP server config (only used by `npm run server:http`) ---
# Port the HTTP MCP server binds to.
PORT=3333
# URL path for the MCP endpoint.
MCP_ENDPOINT=/mcp
# Bearer token gating the endpoint. REQUIRED for any public deploy; the same
# value goes into the Claude.ai Connector config under "Authorization: Bearer ...".
# Generate one with `openssl rand -hex 32`.
MCP_AUTH_TOKEN=
