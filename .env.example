# Panda Video API key (the literal string, no "Bearer" prefix — Panda uses it raw in the Authorization header)
PANDA_API_KEY=panda-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Folder ID for the course inside Panda (VMA folder by default)
PANDA_FOLDER_ID=1c52c2e9-500e-4fde-b2aa-35e9f0aa5c11

# OpenAI API key — used for Whisper transcription (whisper-1, returns verbose_json with timestamps)
# ~$0.006/min ≈ $0.60 for the full 13-lesson VMA course.
OPENAI_API_KEY=sk-...

# Course language (ISO-639-1) — passed to Whisper to lock the target language
COURSE_LANG=pt

# --- HTTP server config (only used by `npm run server:http`) ---
# Port the HTTP MCP server binds to.
PORT=3333
# URL path for the MCP endpoint.
MCP_ENDPOINT=/mcp
# Bearer token gating the endpoint. REQUIRED for any public deploy; the same
# value goes into the Claude.ai Connector config under "Authorization: Bearer ...".
# Generate one with `openssl rand -hex 32`.
MCP_AUTH_TOKEN=

# Optional: dedicated origin for hosting the ChatGPT Apps SDK widget HTML.
# If unset, ChatGPT serves it from https://web-sandbox.oaiusercontent.com.
# REQUIRED for App Store submission. Format: "https://your.domain"
WIDGET_DOMAIN=

# Experimental: use the <video>+hls.js widget on the ChatGPT (/mcp-gpt) endpoint
# instead of the default iframe-to-Panda widget. Useful for testing whether
# ChatGPT's media-src CSP now allows blob: + Panda CDN, which would let us
# drop the iframe path (Apps Directory review rejects iframe apps more often).
# Default: false (keep the iframe path that's known to work).
GPT_USE_VIDEO=false

# --- Supabase (Phase 0+: multi-tenant data layer) ---
# See docs/SUPABASE_SETUP.md for how to provision.
# Required from Sub-phase 0.2 onwards.

# Project URL — found in Supabase dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# service_role key — NEVER commit; used by server only. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# anon (public) key — safe to expose; used by frontend in later phases.
SUPABASE_ANON_KEY=

# Direct Postgres connection for batch queries / migrations.
# Use the POOLER url (port 6543), NOT the direct connection (5432).
# Format: postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# --- Phase 1: OAuth + Magic Link + Hotmart ---

# Public-facing base URL of the MCP server, no trailing slash. Used to build
# OAuth metadata, magic-link callbacks, and tenant-scoped URLs.
# Local dev: http://localhost:3333  | EasyPanel: https://mcp-infosaas-mcp-agentclass.zdnmrb.easypanel.host
PUBLIC_URL=http://localhost:3333

# Resend API key for sending magic-link emails. Get one at https://resend.com.
# When unset, magic-link URLs are logged to stderr (dev only).
RESEND_API_KEY=

# Email sender for magic links. Must be a verified Resend domain in production.
RESEND_FROM=Askine <login@askine.com.br>
